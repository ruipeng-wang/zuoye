# LLM 配置（OpenAI 兼容接口）
llm:
  model: "deepseek-chat"
  base_url: "https://api.deepseek.com/v1"
  api_key: "${DEEPSEEK_API_KEY}"
  temperature: 0.1
  max_tokens: 2048

# Embedding 配置（OpenAI 兼容接口）
embedding:
  model: "BAAI/bge-large-zh-v1.5"
  base_url: "https://api.siliconflow.cn/v1"
  api_key: "${SILICONFLOW_API_KEY}"

# Rerank 配置（可选）
rerank:
  model: "BAAI/bge-reranker-v2-m3"
  base_url: "https://api.siliconflow.cn/v1"
  api_key: "${SILICONFLOW_API_KEY}"
  enabled: true

# 检索配置
retrieval:
  top_k: 10
  bm25_top_k: 5
  rerank_top_k: 5
  expand_neighbors: true

# 切分配置
chunking:
  text:
    chunk_size: 512
    chunk_overlap: 128
  table:
    rows_per_group: 8
    overlap_rows: 3
    max_rows_single_chunk: 8